PORT=5000

# If Chrome is non-standard, point Puppeteer at the binary explicitly (optional)
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# QuickCommerce (https://quickcommerceapi.com/docs) — real catalog + prices by lat/lon.
# Blinkit uses GET /v1/search; other stores use GET /v1/groupsearch (comma-separated).
QUICKCOMMERCE_API_KEY=
# QUICKCOMMERCE_API_BASE=https://api.quickcommerceapi.com

# Platforms for groupsearch (default excludes Blinkit — Blinkit uses dedicated /v1/search).
QUICKCOMMERCE_GROUP_PLATFORMS=Zepto,Swiggy,BigBasket

# Seconds-class cache grid (milliseconds)
SEARCH_CACHE_TTL_MS=75000

# Grid precision for grouping nearby identical searches (decimals on lat/lon)
SEARCH_GRID_DECIMALS=3

# Optional pincode for platforms that require it (DMart / JioMart etc., not primary NEXUS set)
DEFAULT_PINCODE=

